# =============================================================================
# ClawPort — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# See SETUP.md for detailed instructions on finding each value.
# =============================================================================

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Path to your OpenClaw workspace directory.
# Default location: ~/.openclaw/workspace
# Find yours: ls ~/.openclaw/workspace
WORKSPACE_PATH=/Users/yourname/.openclaw/workspace

# Path to the openclaw CLI binary.
# Find yours: which openclaw
OPENCLAW_BIN=/usr/local/bin/openclaw

# OpenClaw gateway authentication token.
# All API calls (chat, vision, TTS, transcription) use this token.
# Find yours: openclaw gateway status
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# OpenClaw gateway port (default: 18789).
# Change this if you configured a custom port in openclaw.json (gateway.http.port).
# OPENCLAW_GATEWAY_PORT=18789

# Optional: route text chat through the local DGX Nemotron server instead of the
# OpenClaw gateway. When enabled, ClawPort adds an evidence-first reasoning
# policy, forces thinking on, and uses the local model for text chat routes.
# Image chat still uses the OpenClaw gateway path.
# You can point DGX_CHAT_BASE_URL either at the DGX directly:
#   http://192.168.5.73:8000/v1
# or at the shared local gateway described in /Users/josearango/Desktop/DGX Patch/integration/README.md:
#   http://localhost:8787/v1
# If you use the shared gateway, set DGX_CHAT_API_KEY to that gateway key.
# DGX_CHAT_ENABLED=1
# DGX_CHAT_BASE_URL=http://192.168.5.73:8000/v1
# DGX_CHAT_MODEL=nvidia/nemotron-3-super-120b-a12b
# DGX_CHAT_API_KEY=not-needed
# DGX_CHAT_MAX_TOKENS=1200
# DGX_SHOW_REASONING=0

# ElevenLabs API key — enables voice indicators on agent profiles.
# Get one at: https://elevenlabs.io
# Leave blank or remove this line if you don't need voice features.
# ELEVENLABS_API_KEY=sk_your-elevenlabs-key-here

# Optional: override the built-in Stephany conversational agent page.
# By default ClawPort points /stephany at the deployed public agent below.
# NEXT_PUBLIC_ELEVENLABS_STEPHANY_AGENT_ID=agent_4101km8sfn8memhve210pcmpr5sb
# NEXT_PUBLIC_ELEVENLABS_STEPHANY_AGENT_NAME=Stephany

# Optional: override the shared Stephany runtime coaching pack path.
# By default ClawPort reads:
#   ~/.openclaw/skills/stephany-training/data/RUNTIME_CONTEXT.md
# STEPHANY_TRAINING_CONTEXT_PATH=/absolute/path/to/RUNTIME_CONTEXT.md
